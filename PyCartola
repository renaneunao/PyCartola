    def adicionar_coluna_posicao_jogador(self):
        def rodada_atual():
            response = requests.get("https://api.cartolafc.globo.com/mercado/status")
            # Verifica se a solicitação foi bem-sucedida
            if response.status_code == 200:
                # Extrai os dados JSON da resposta
                data = response.json()
                rodada_atual = data["rodada_atual"]
                return rodada_atual
        # Função para obter os dados de uma rodada específica da API do Cartola
        def obter_dados_rodada(rodada):
            url = f"https://api.cartola.globo.com/atletas/pontuados/{rodada}"
            response = requests.get(url)
            if response.status_code == 200:
                data = response.json()
                if 'atletas' in data:
                    return data
                else:
                    return None
            else:
                if rodada == 1:
                    print(f"Falha ao obter dados da rodada {rodada}. Status code: {response.status_code}")
                return None
        # Função para criar o DataFrame com os dados de todas as rodadas
        def criar_dataframe():
            # Inicializando listas para armazenar os dados de todas as rodadas
            dados_rodadas = []
            atletas_ids = []

            # Iterando sobre as rodadas de 1 a 38
            for rodada in range(1, 39):
                dados_rodada = obter_dados_rodada(rodada)
                if dados_rodada:
                    # Adicionando os dados da rodada à lista
                    dados_rodadas.append(dados_rodada)
                    # Adicionando os IDs dos jogadores à lista
                    atletas_ids.extend(dados_rodada['atletas'].keys())
                else:
                    break  # Encerra o loop se ocorrer um erro na primeira iteração

            if dados_rodadas:
                # Concatenando os dados de todas as rodadas em um único DataFrame
                df = pd.concat([pd.DataFrame(rodada['atletas'].values()) for rodada in dados_rodadas])

                # Adicionando a coluna "rodada" com o número da rodada correspondente
                df['rodada'] = [dados_rodada['rodada'] for dados_rodada in dados_rodadas for _ in
                                range(len(dados_rodada['atletas']))]

                # Adicionando a coluna "atleta_id"
                df['atleta_id'] = atletas_ids

                # Explorando a coluna 'scout' em colunas individuais
                df_scout = json_normalize(df['scout'])
                # Resetando os índices para evitar duplicatas
                df.reset_index(drop=True, inplace=True)
                df_scout.reset_index(drop=True, inplace=True)
                # Concatenando as colunas de scout com o DataFrame original
                df = pd.concat([df, df_scout], axis=1)
                # Removendo a coluna 'scout' original
                df = df.drop(columns=['scout'])

                # Reorganizando as colunas na ordem desejada
                df = df[['atleta_id', 'apelido', 'foto', 'posicao_id', 'clube_id', 'entrou_em_campo', 'pontuacao',
                         'rodada'] + df_scout.columns.tolist()]

                # Renomeando a coluna rodada para rodada_id
                df = df.rename(columns={'rodada': 'rodada_id'})
                return df
            else:
                return None
        # Criando o DataFrame com os dados de todas as rodadas
        df_pontuados = criar_dataframe()

        # Adicionando a coluna nome_completo à planilha
        # Faz a solicitação GET para a API
        response = requests.get("https://api.cartola.globo.com/atletas/mercado")

        # Verifica se a solicitação foi bem-sucedida
        if response.status_code == 200:
            # Extrai os dados JSON da resposta
            data = response.json()

            # Inicializa listas para armazenar os atleta_id e nomes
            atleta_ids = []
            nomes = []

            # Itera sobre os atletas no mercado e extrai os dados necessários
            for atleta in data['atletas']:
                atleta_ids.append(atleta['atleta_id'])
                nomes.append(atleta['nome'])

            # Cria um DataFrame com os dados extraídos
            df_mercado = pd.DataFrame({'atleta_id': atleta_ids, 'nome': nomes})
        else:
            print("Falha ao obter os dados da API.")
        df_pontuados['atleta_id'] = df_pontuados['atleta_id'].astype(int)
        df_mercado['atleta_id'] = df_mercado['atleta_id'].astype(int)

        # Merging df_pontuados with df based on 'atleta_id'
        df_pontuados = df_pontuados.merge(df_mercado, on='atleta_id', how='left')

        # Colocar a coluna 'nome' depois da coluna 'apelido'
        apelido_index = df_pontuados.columns.get_loc('apelido')
        df_pontuados.insert(apelido_index + 1, 'nome', df_pontuados.pop('nome'))

        # Adicionar coluna posicao_jogador
        # Carregar as planilhas
        caminho_jogadores_posicao = r'C:\Users\renan\OneDrive\Documentos\API_CARTOLA\jogadores-posicoes\jogadores_posicao.xlsx'
        jogadores_posicao = pd.read_excel(caminho_jogadores_posicao)

        # Função para remover acentos
        def remover_acentos(texto):
            return unidecode(texto)

        # Transformar a coluna 'nome' em string
        df_pontuados['nome'] = df_pontuados['nome'].astype(str).apply(remover_acentos)

        jogadores_posicao['Nome'] = jogadores_posicao['Nome'].apply(remover_acentos)

        planilha_associada = pd.merge(df_pontuados, jogadores_posicao, how='left',
                                      left_on=['clube_id', 'nome'], right_on=['clube_id', 'Nome'])


        # Função para calcular a similaridade entre strings
        def similar(a, b):
            return SequenceMatcher(None, a, b).ratio()

        # Preencher a coluna 'Posição' com base na similaridade dos nomes dos jogadores
        def preencher_posicao(row):
            if pd.isnull(row['Posição']):
                jogadores_mesmo_clube = jogadores_posicao[jogadores_posicao['clube_id'] == row['clube_id']]
                max_sim = -1
                posicao = None
                for index, jogador in jogadores_mesmo_clube.iterrows():
                    sim = similar(row['nome'], jogador['Nome'])
                    if sim > max_sim:
                        max_sim = sim
                        posicao = jogador['Posição']
                if max_sim > 0.6:  # Define o limite de similaridade
                    return posicao
            return row['Posição']

        planilha_associada['Posição'] = planilha_associada.apply(preencher_posicao, axis=1)

        # Reorganizar as colunas para posicionar a coluna 'Posição' após a coluna 'posicao_id'
        colunas = list(planilha_associada.columns)
        planilha_associada = planilha_associada[colunas]
        planilha_associada = planilha_associada.drop(columns=['Nome', 'Time'])
        planilha_associada.rename(columns={'Posição': 'posicao_jogador'}, inplace=True)

        # Iterate over the rows
        for index, row in planilha_associada.iterrows():
            posicao_id = str(row['posicao_id'])
            if posicao_id in self.posicoes:
                nome_posicao = self.posicoes[posicao_id]['nome']
                # Check if 'posicao_jogador' is empty
                if pd.isnull(row['posicao_jogador']):
                    # Fill the empty 'posicao_jogador' with the corresponding 'nome' value
                    planilha_associada.at[index, 'posicao_jogador'] = nome_posicao

        # Colocar a coluna 'posicao_jogador' depois da coluna 'posicao_id'
        posicao_id_index = planilha_associada.columns.get_loc('posicao_id')
        planilha_associada.insert(posicao_id_index + 1, 'posicao_jogador', planilha_associada.pop('posicao_jogador'))

        # Substituir 'VERDADEIRO' por 1 e 'FALSO' por 0 na coluna 'entrou_em_campo'
        planilha_associada['entrou_em_campo'] = planilha_associada['entrou_em_campo'].astype(bool).map({True: 1, False: 0})


