        pontuados_completo['adversario_id'] = ''
        pontuados_completo['mando'] = ''

        def procurar_adversario(row):
            print(f"\rProcurando adversário para {row['nome']} na rodada {row['rodada_id']}...", end='')
            # Se o 'clube_id' for diferente de vazio, então o mando é CASA
            adversario_id = \
            self.df_rodadas[(self.df_rodadas['rodada_id'] == row['rodada_id']) & (self.df_rodadas['clube_id'] == row['clube_id'])][
                'clube_visitante_id'].values
            if len(adversario_id) > 0:
                pontuados_completo.at[row.name, 'mando'] = 'CASA'
                return adversario_id[0]
            else:
                adversario_id = self.df_rodadas[(self.df_rodadas['rodada_id'] == row['rodada_id']) & (
                            self.df_rodadas['clube_visitante_id'] == row['clube_id'])]['clube_id'].values
                if len(adversario_id) > 0:
                    pontuados_completo.at[row.name, 'mando'] = 'FORA'
                    return adversario_id[0]
                else:
                    return None  # Se não encontrou adversário, retorna None

        # Adicionar valores à coluna adversario_id
        pontuados_completo['adversario_id'] = pontuados_completo.apply(procurar_adversario, axis=1)
        print('')
        print(f'Adversários encontrados: {pontuados_completo["adversario_id"].notna().sum()}')

        # Colocar a coluna 'adversario_id' depois da coluna 'clube_id'
        posicao_id_index = pontuados_completo.columns.get_loc('clube_id')
        pontuados_completo.insert(posicao_id_index + 1, 'adversario_id', pontuados_completo.pop('adversario_id'))
        print(f'Adversários colocados: {pontuados_completo["adversario_id"].notna().sum()}')

        # Colocar a coluna 'mando' depois da coluna 'rodada_id'
        mando_index = pontuados_completo.columns.get_loc('rodada_id')
        pontuados_completo.insert(mando_index + 1, 'mando', pontuados_completo.pop('mando'))
        print(f'Mandos colocados: {pontuados_completo["mando"].notna().sum()}')

        # Para cada scout, criar uma coluna com o nome 'adv_SCOUT_c' e 'adv_SCOUT_f' onde vamos agrupar por scout cedido pelo adversario_id. Se o sufixo for c então o mando tem que ser CASA e se o sufixo for f então o mando tem que ser FORA
