    def adicionar_adversario_id_e_mando(self):
        def rodada_atual():
            response = requests.get("https://api.cartolafc.globo.com/mercado/status")
            # Verifica se a solicitação foi bem-sucedida
            if response.status_code == 200:
                # Extrai os dados JSON da resposta
                data = response.json()
                rodada_atual = data["rodada_atual"]
                return rodada_atual
        # Criar coluna chamada adversario_id que buscará o atleta_id do jogador na planilha rodadas.xlsx
        self.df_rodadas = pd.DataFrame(columns=["rodada_id", "clube_id", "clube_visitante_id"])  # Cria um DataFrame vazio
        for rodada in range(1, (rodada_atual() + 1)):
            print(f"Rodada {rodada}: Carregado!")
            url = f"https://api.cartola.globo.com/partidas/{rodada}"
            response = requests.get(url)

            if response.status_code == 200:
                data = response.json()
                partidas = data["partidas"]

                # Itera sobre as partidas da rodada atual
                for partida in partidas:
                    clube_mandante = partida["clube_casa_id"]
                    clube_visitante = partida["clube_visitante_id"]
                    self.df_rodadas = self.df_rodadas._append(
                        {"rodada_id": rodada, "clube_id": clube_mandante, "clube_visitante_id": clube_visitante},
                        ignore_index=True)
            else:
                messagebox.showerror("Erro",
                                     f"Falha ao acessar a API da rodada {rodada}. Código de status: {response.status_code}")

        # Adiciona uma coluna vazia na planilha_associada chamada adversario_id e uma de mando
        self.df_mercado['adversario_id'] = ''
        self.df_mercado['mando'] = ''

        def procurar_adversario(row):
            print(f"\rProcurando adversário para {row['nome']} na rodada {row['rodada_id']}...", end='')
            # Se o 'clube_id' for diferente de vazio, então o mando é CASA
            adversario_id = \
            self.df_rodadas[(self.df_rodadas['rodada_id'] == row['rodada_id']) & (self.df_rodadas['clube_id'] == row['clube_id'])][
                'clube_visitante_id'].values
            if len(adversario_id) > 0:
                self.df_mercado.at[row.name, 'mando'] = 'CASA'
                return adversario_id[0]
            else:
                adversario_id = self.df_rodadas[(self.df_rodadas['rodada_id'] == row['rodada_id']) & (
                            self.df_rodadas['clube_visitante_id'] == row['clube_id'])]['clube_id'].values
                if len(adversario_id) > 0:
                    self.df_mercado.at[row.name, 'mando'] = 'FORA'
                    return adversario_id[0]
                else:
                    return None  # Se não encontrou adversário, retorna None

        # Adicionar valores à coluna adversario_id
        self.df_mercado['adversario_id'] = self.df_mercado.apply(procurar_adversario, axis=1)
        print('')
        # print(f'Adversários encontrados: {self.df_mercado["adversario_id"].notna().sum()}')

        # Colocar a coluna 'adversario_id' depois da coluna 'clube_id'
        posicao_id_index = self.df_mercado.columns.get_loc('clube_id')
        self.df_mercado.insert(posicao_id_index + 1, 'adversario_id', self.df_mercado.pop('adversario_id'))
        # print(f'Adversários colocados: {self.df_mercado["adversario_id"].notna().sum()}')

        # Colocar a coluna 'mando' depois da coluna 'rodada_id'
        mando_index = self.df_mercado.columns.get_loc('rodada_id')
        self.df_mercado.insert(mando_index + 1, 'mando', self.df_mercado.pop('mando'))
        # print(f'Mandos colocados: {self.df_mercado["mando"].notna().sum()}')

        # print(self.df_mercado)
