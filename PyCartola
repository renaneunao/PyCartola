        planilha_associada_mando_casa = pontuados_completo[pontuados_completo['mando'] == 'CASA']
        planilha_associada_mando_fora = pontuados_completo[pontuados_completo['mando'] == 'FORA']

        # Agora em cada coluna de scout criada, agrupar o somatorio de 'adv_SCOUT_c' e 'adv_SCOUT_f' por 'adversario_id' e 'posicao_id' em cada coluna de scout
        for scout in self.scouts:
